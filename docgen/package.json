{
  "name": "docgen",
  "version": "0.1.0",
  "description": "Static-analysis documentation generator with multi-level Mermaid diagrams",
  "type": "module",
  "main": "dist/docgen.js",
  "bin": {
    "docgen": "dist/docgen.js"
  },
  "scripts": {
    "build": "node esbuild.config.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@google/genai": "^1.0.0",
    "tree-sitter-wasms": "^0.1.13",
    "web-tree-sitter": "^0.24.7",
    "yaml": "^2.7.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "esbuild": "^0.25.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3",
    "vitest": "^3.1.1"
  }
}
